# Шаблон окружения time-credos-ru. Скопируй в .env и заполни РЕАЛЬНЫМИ значениями.
# .env — gitignored. Сюда (.env.example) РЕАЛЬНЫЕ значения НЕ писать.

# --- Twenty dev-сервер (Railway «Twenty Credos Time», Twenty 2.14) ---
TWENTY_DEV_URL=https://twenty-production-e5c5.up.railway.app
TWENTY_DEV_API_KEY=        # API key с АДМИН-ролью (Settings → API & Webhooks). Не playground (живёт 2ч).
TWENTY_DEV_EMAIL=          # логин админа workspace (для разовых операций)
TWENTY_DEV_PASSWORD=       # пароль админа workspace

# --- Railway CLI (project-scoped токен проекта «Twenty Credos Time») ---
RAILWAY_TOKEN=             # project token (railway → Settings → Tokens)
RAILWAY_PROJECT_ID=0f4c3f20-1af6-463f-9c69-3a5f953c8d07
</content>
